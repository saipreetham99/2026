#!/usr/bin/env python3
"""
Button UI for the fixed-command pool test (real sub). Same behaviour as pool_test.py:
each motion button drives ONE DOF at a fixed level for a fixed duration through the exact
driver mix and <7H packet, then neutral so the sub glides to rest.

Kids just set Duration once, then tap Forward / Backward / etc. STOP aborts and neutralises
at any time. Uses pygame (already installed) so there is nothing extra to set up.

Run from the same folder as your .rov_server_creds:
    python real_test_gui.py
"""

import configparser
import os
import socket
import struct
import sys
import threading
import time

import pygame

NEUTRAL = 1500
LIGHT_OFF = 1100


# ---- core (identical to pool_test.py) ----


def clamp(x):
    return max(-1.0, min(1.0, x))


def mix(surge, strafe, heave, yaw):
    fl = clamp(surge - strafe - yaw)
    fr = clamp(surge + strafe + yaw)
    rl = clamp(surge + strafe - yaw)
    rr = clamp(surge - strafe + yaw)
    v1 = clamp(heave)
    v2 = clamp(-heave)
    return fl, fr, rl, rr, v1, v2


def to_pwm(x, amp):
    return int(NEUTRAL + x * amp)


def thruster_packet(thr, amp):
    fl, fr, rl, rr, v1, v2 = thr
    return struct.pack(
        "<7H",
        to_pwm(fl, amp),
        to_pwm(fr, amp),
        to_pwm(rl, amp),
        to_pwm(rr, amp),
        to_pwm(v1, amp),
        to_pwm(v2, amp),
        LIGHT_OFF,
    )


def neutral_packet():
    return struct.pack("<7H", *([NEUTRAL] * 6), LIGHT_OFF)


def load_config(mode):
    path = os.path.expanduser(".rov_server_creds")
    cfg = configparser.ConfigParser()
    if not os.path.exists(path) or not cfg.read(path):
        raise RuntimeError(f"Config not found/empty at '{path}'")
    try:
        rov_ip = cfg[mode]["rov_ip"]
        thruster_port = cfg.getint("DEFAULT", "thruster_port")
    except (KeyError, configparser.NoSectionError) as e:
        raise RuntimeError(f"Missing section/key in config: {e}")
    return (rov_ip, thruster_port), cfg


def capture_sensors(port, out_path, stop_event):
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    s.bind(("", port))
    s.settimeout(0.2)
    t0 = time.time()
    with open(out_path, "w") as f:
        f.write("t_seconds,length,hex\n")
        while not stop_event.is_set():
            try:
                data, _ = s.recvfrom(4096)
            except socket.timeout:
                continue
            f.write(f"{time.time() - t0:.4f},{len(data)},{data.hex()}\n")
    s.close()


# ---- button helper ----


class Button:
    def __init__(self, rect, label, action, color=(70, 90, 120), enabled=None):
        self.rect = pygame.Rect(rect)
        self.label = label  # str or callable
        self.action = action
        self.color = color
        self.enabled = enabled or (lambda: True)

    def text(self):
        return self.label() if callable(self.label) else self.label

    def draw(self, surf, font):
        on = self.enabled()
        pygame.draw.rect(
            surf, self.color if on else (55, 55, 60), self.rect, border_radius=8
        )
        pygame.draw.rect(surf, (200, 200, 200), self.rect, width=2, border_radius=8)
        t = font.render(self.text(), True, (255, 255, 255) if on else (110, 110, 110))
        surf.blit(t, t.get_rect(center=self.rect.center))

    def click(self, pos):
        if self.enabled() and self.rect.collidepoint(pos):
            self.action()
            return True
        return False


# ---- app ----


class App:
    def __init__(self):
        pygame.init()
        self.W, self.H = 700, 690
        self.screen = pygame.display.set_mode((self.W, self.H))
        pygame.display.set_caption("Sub Pool Test")
        self.f_title = pygame.font.SysFont("Helvetica", 26, bold=True)
        self.f_btn = pygame.font.SysFont("Helvetica", 20, bold=True)
        self.f_small = pygame.font.SysFont("Helvetica", 16)
        self.f_status = pygame.font.SysFont("Helvetica", 22, bold=True)

        # settings
        self.mode = "lan"
        self.duration = 3
        self.amp = 100
        self.capture = False
        self.rate = 50.0
        self.countdown = 3

        # runtime
        self.running = False
        self.abort = False
        self.status = "Ready"
        self.log = []
        self.lock = threading.Lock()
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)

        idle = lambda: not self.running
        self.buttons = []

        # settings row
        self.buttons.append(
            Button(
                (40, 70, 150, 40),
                lambda: f"Mode: {self.mode.upper()}",
                self.toggle_mode,
                (90, 90, 130),
                idle,
            )
        )
        self.buttons.append(
            Button((250, 70, 40, 40), "-", lambda: self.set_dur(-1), (80, 80, 90), idle)
        )
        self.buttons.append(
            Button((360, 70, 40, 40), "+", lambda: self.set_dur(+1), (80, 80, 90), idle)
        )
        self.buttons.append(
            Button(
                (470, 70, 40, 40), "-", lambda: self.set_amp(-100), (80, 80, 90), idle
            )
        )
        self.buttons.append(
            Button(
                (580, 70, 40, 40), "+", lambda: self.set_amp(+100), (80, 80, 90), idle
            )
        )
        self.buttons.append(
            Button(
                (40, 125, 200, 34),
                lambda: f"Capture: {'ON' if self.capture else 'OFF'}",
                self.toggle_capture,
                (90, 110, 90),
                idle,
            )
        )

        # motion grid
        grid = [
            ("Forward", "surge", 1),
            ("Backward", "surge", -1),
            ("Strafe Left", "strafe", -1),
            ("Strafe Right", "strafe", 1),
            ("Up", "heave", 1),
            ("Down", "heave", -1),
            ("Yaw Left", "yaw", -1),
            ("Yaw Right", "yaw", 1),
        ]
        bx, by, bw, bh, gx, gy = 40, 180, 300, 55, 20, 14
        for i, (label, motion, sign) in enumerate(grid):
            col, row = i % 2, i // 2
            r = (bx + col * (bw + gx), by + row * (bh + gy), bw, bh)
            self.buttons.append(
                Button(
                    r,
                    label,
                    lambda m=motion, s=sign: self.start(m, s),
                    (70, 90, 120),
                    idle,
                )
            )

        # STOP (always enabled)
        stop_y = by + 4 * (bh + gy) + 6
        self.buttons.append(
            Button(
                (40, stop_y, bw * 2 + gx, 60),
                "STOP",
                self.stop,
                (170, 60, 60),
                lambda: True,
            )
        )
        self.status_y = stop_y + 72

    # settings actions
    def toggle_mode(self):
        self.mode = "wifi" if self.mode == "lan" else "lan"

    def toggle_capture(self):
        self.capture = not self.capture

    def set_dur(self, d):
        self.duration = max(1, min(15, self.duration + d))

    def set_amp(self, d):
        self.amp = max(100, min(400, self.amp + d))

    def set_status(self, s):
        with self.lock:
            self.status = s

    def add_log(self, s):
        with self.lock:
            self.log.append(s)
            self.log = self.log[-6:]

    # run control
    def start(self, motion, sign):
        if self.running:
            return
        self.running = True
        self.abort = False
        threading.Thread(target=self._worker, args=(motion, sign), daemon=True).start()

    def stop(self):
        self.abort = True
        try:
            addr, _ = load_config(self.mode)
            for _ in range(5):
                self.sock.sendto(neutral_packet(), addr)
        except Exception:
            pass
        self.set_status("STOP - neutral sent")

    def _worker(self, motion, sign):
        try:
            addr, cfg = load_config(self.mode)
        except Exception as e:
            self.set_status(f"ERROR: {e}")
            self.running = False
            return

        cmd = {"surge": 0.0, "strafe": 0.0, "heave": 0.0, "yaw": 0.0}
        cmd[motion] = float(sign)
        thr = mix(cmd["surge"], cmd["strafe"], cmd["heave"], cmd["yaw"])
        packet = thruster_packet(thr, self.amp)
        label = f"{motion} {'+' if sign > 0 else '-'}"
        self.add_log(f"{label}  amp={self.amp}  {self.duration}s -> {addr[0]}")

        stop_event = threading.Event()
        cap_thread = None
        if self.capture:
            try:
                port = cfg.getint("DEFAULT", "imu_and_depth_port")
                fname = f"capture_{motion}_{'+' if sign > 0 else '-'}_{time.strftime('%H%M%S')}.csv"
                cap_thread = threading.Thread(
                    target=capture_sensors, args=(port, fname, stop_event), daemon=True
                )
                cap_thread.start()
                self.add_log(f"recording -> {fname}")
            except Exception as e:
                self.add_log(f"capture failed: {e}")

        self.sock.sendto(neutral_packet(), addr)
        dt = 1.0 / self.rate

        for i in range(self.countdown, 0, -1):
            if self.abort:
                break
            self.set_status(f"Starting in {i}...")
            time.sleep(1.0)

        if not self.abort:
            self.set_status(f">>> GO  ({label})")
            t_next = time.time()
            t_end = t_next + self.duration
            while time.time() < t_end and not self.abort:
                self.sock.sendto(packet, addr)
                t_next += dt
                d = t_next - time.time()
                if d > 0:
                    time.sleep(d)
                else:
                    t_next = time.time()
            self.set_status(
                "ABORTED" if self.abort else ">>> STOP - measure start to rest"
            )

        for _ in range(int(0.5 / dt) + 1):
            self.sock.sendto(neutral_packet(), addr)
            time.sleep(dt)
        stop_event.set()
        if cap_thread:
            cap_thread.join(timeout=1.0)
        self.running = False

    def run(self):
        clock = pygame.time.Clock()
        while True:
            for e in pygame.event.get():
                if e.type == pygame.QUIT:
                    self.abort = True
                    try:
                        addr, _ = load_config(self.mode)
                        self.sock.sendto(neutral_packet(), addr)
                    except Exception:
                        pass
                    pygame.quit()
                    return
                if e.type == pygame.MOUSEBUTTONDOWN and e.button == 1:
                    for b in self.buttons:
                        if b.click(e.pos):
                            break
            self.draw()
            clock.tick(30)

    def draw(self):
        s = self.screen
        s.fill((30, 32, 38))
        s.blit(self.f_title.render("Sub Pool Test", True, (240, 240, 240)), (40, 22))

        # captions for steppers
        s.blit(self.f_small.render("Duration", True, (180, 180, 180)), (250, 50))
        s.blit(self.f_small.render("AMP", True, (180, 180, 180)), (470, 50))
        s.blit(
            self.f_status.render(f"{self.duration}s", True, (255, 255, 255)), (300, 76)
        )
        s.blit(self.f_status.render(f"{self.amp}", True, (255, 255, 255)), (515, 76))

        for b in self.buttons:
            b.draw(s, self.f_btn)

        with self.lock:
            status = self.status
            log = list(self.log)
        s.blit(self.f_status.render(status, True, (255, 230, 120)), (40, self.status_y))
        for i, line in enumerate(log):
            s.blit(
                self.f_small.render(line, True, (170, 170, 175)),
                (40, self.status_y + 34 + i * 20),
            )

        pygame.display.flip()


if __name__ == "__main__":
    App().run()
